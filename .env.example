# === Telegram ===
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_ALLOWED_USERS=

# === OpenCode Engine ===
OPENCODE_HOST=http://127.0.0.1
OPENCODE_PORT=4096
# 设置为 Muse 项目根目录的绝对路径
OPENCODE_WORKSPACE=/path/to/muse

# === Models ===
# oh-my-opencode.json 优先级更高，切模型需同时改那个文件
# 见 .agents/skills/opencode-config/SKILL.md
DEFAULT_PROVIDER=minimax
DEFAULT_MODEL=MiniMax-M2.5
HEAVY_PROVIDER=minimax
HEAVY_MODEL=MiniMax-M2.5

# === Image Generation (可选, 有免费 fallback) ===
# DASHSCOPE_API_KEY=your-dashscope-key
# SILICONFLOW_API_KEY=your-siliconflow-key

# === Memory ===
MEMORY_DB_PATH=./data/memory.db

# === Web Cockpit ===
WEB_PORT=4097
WEB_HOST=127.0.0.1

# === Daemon ===
HEARTBEAT_INTERVAL=30000
MAX_HEARTBEAT_FAILURES=3
LOG_LEVEL=info
